# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# monorepo 全局规则：不加前导斜杠，所有子包一并生效。

# 依赖
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 构建产物
dist
build
out
.next
.turbo
.swc

# 测试
coverage

# 环境变量（如需提交模板，请提交 .env.example）
.env
.env.*
!.env.example

# 日志
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.pnpm-debug.log*

# 编辑器 / 系统
.DS_Store
.idea
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.pem

# TypeScript 增量缓存
*.tsbuildinfo

# 部署
.vercel
