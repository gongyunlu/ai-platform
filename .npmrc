# 锁 node / pnpm 版本
engine-strict=true

# 保持默认 hoist 行为
# 显式声明常见需要提升的类型包，减少幽灵依赖
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# 装依赖时严格按 lockfile
# 本地需要更新时用 pnpm install --no-frozen-lockfile 显式解锁
frozen-lockfile=true

# 不允许把 workspace 包意外发布出去
save-workspace-protocol=rolling
